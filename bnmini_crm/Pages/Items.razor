@code {
    [Parameter, SupplyParameterFromQuery] public int VenueId { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var chatId = await JS.InvokeAsync<long>("getTelegramUserId");
                var items = Db.Items.Where(i => i.VenueId == VenueId).ToList();

                string? firstName = null;
                int? appUserId = null;

                if (chatId != 0)
                {
                    var user = Db.AppUsers.FirstOrDefault(u => u.TelegramUserId == chatId);
                    if (user != null) { firstName = user.FirstName; appUserId = user.Id; }
                }
                else
                {
                    var uri = new Uri(Nav.Uri);
                    var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                    var testUserId = query["testUserId"];
                    if (!string.IsNullOrEmpty(testUserId) && int.TryParse(testUserId, out var tid))
                    {
                        var user = Db.AppUsers.FirstOrDefault(u => u.Id == tid);
                        if (user != null) { firstName = user.FirstName; appUserId = user.Id; }
                    }
                }

                // Загрузить адреса и телефон сразу
                string? phone = null;
                List<string> addresses = new();
                if (appUserId != null)
                {
                    var appUser = Db.AppUsers.FirstOrDefault(u => u.Id == appUserId);
                    phone = appUser?.Phone;
                    addresses = Db.DeliveryAddresses
                        .Where(a => a.AppUserId == appUserId)
                        .OrderByDescending(a => a.CreatedAt)
                        .Select(a => a.Label)
                        .ToList();
                }

                // Загрузить категории
                var categories = Db.Categories
                    .Where(c => c.VenueId == VenueId)
                    .OrderBy(c => c.SortOrder)
                    .Select(c => new { c.Id, c.Name, c.IsDefault })
                    .ToList();

                var defaultCategoryId = categories.FirstOrDefault(c => c.IsDefault)?.Id ?? 0;

                var itemsJson = JsonSerializer.Serialize(items.Select(i => new
                {
                    i.Id,
                    i.Name,
                    i.Description,
                    Price = i.Price,
                    i.ImageUrl,
                    CategoryId = i.CategoryId ?? 0
                }));

                var categoriesJson = JsonSerializer.Serialize(categories);
                var addressesJson = JsonSerializer.Serialize(addresses);

                await JS.InvokeVoidAsync("initShop",
             itemsJson, firstName ?? "", appUserId ?? 0, VenueId,
             phone ?? "", addressesJson,
             categoriesJson, defaultCategoryId);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error: {ex.Message}");
            }
        }
    }
}