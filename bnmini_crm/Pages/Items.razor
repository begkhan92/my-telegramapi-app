@code {
    [Parameter, SupplyParameterFromQuery] public int VenueId { get; set; }
    [Parameter, SupplyParameterFromQuery] public int UserId { get; set; }

    private string _itemsJson = "[]";
    private string _categoriesJson = "[]";
    private string _addressesJson = "[]";
    private string _firstName = "";
    private string _phone = "";
    private int _defaultCategoryId = 0;

    protected override async Task OnInitializedAsync()
    {
        var items = await Db.Items
    .Where(i => i.VenueId == VenueId)
    .Include(i => i.Images)
    .ToListAsync();
        var categories = await Db.Categories
            .Where(c => c.VenueId == VenueId)
            .OrderBy(c => c.SortOrder)
            .ToListAsync();

        string? phone = null;
        List<string> addresses = new();

        if (UserId > 0)
        {
            var user = await Db.AppUsers.FirstOrDefaultAsync(u => u.Id == UserId);
            if (user != null)
            {
                _firstName = user.FirstName ?? "";
                phone = user.Phone;
                addresses = await Db.DeliveryAddresses
                    .Where(a => a.AppUserId == UserId)
                    .OrderByDescending(a => a.CreatedAt)
                    .Select(a => a.Label)
                    .ToListAsync();
            }
        }

        _phone = phone ?? "";
        _defaultCategoryId = categories.FirstOrDefault(c => c.IsDefault)?.Id ?? 0;

        _itemsJson = JsonSerializer.Serialize(items.Select(i => new
        {
            i.Id,
            i.Name,
            i.Description,
            Price = i.Price,
            i.ImageUrl,
            CategoryId = i.CategoryId ?? 0,
            Images = i.Images.OrderBy(img => img.SortOrder).Select(img => new { img.Url }).ToList()
        }));
        _categoriesJson = JsonSerializer.Serialize(categories.Select(c => new { c.Id, c.Name, c.IsDefault }));
        _addressesJson = JsonSerializer.Serialize(addresses);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initShop",
                _itemsJson, _firstName, UserId, VenueId,
                _phone, _addressesJson,
                _categoriesJson, _defaultCategoryId);
        }
    }
}