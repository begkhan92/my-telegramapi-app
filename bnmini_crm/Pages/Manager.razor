@code {
    [Parameter, SupplyParameterFromQuery] public int VenueId { get; set; }
    [Parameter, SupplyParameterFromQuery] public string Token { get; set; } = "";
    [Parameter, SupplyParameterFromQuery] public string? Code { get; set; }

    bool authorized = false;
    bool loading = true;
    string venueName = "";

    int ordersTotal, ordersToday, usersTotal, usersToday, itemsCount, categoriesCount;
    decimal revenueTotal, revenueToday, avgCheck;
    List<ItemRevenueRow> itemRevenue = new();
    List<TimeRow> topTimes = new();
    List<Category> categories = new();
    List<Item> allItems = new();
    Dictionary<int, bool> categoryHasItems = new();

    bool showAddItem, showCategories;
    string newCategoryName = "";
    string addItemError = "";
    string uploadedImageUrl = "";
    bool uploadingPhoto = false;
    int selectedCategoryId;
    Item? editingItem = null;
    Item? itemToDelete = null;
    ItemFormModel itemForm = new();
    int editingCategoryId = 0;
    string editingCategoryName = "";
    bool sendingReport = false;
    string reportStatus = "";
    bool reportSuccess = false;

    record ItemRevenueRow(string Name, int Qty, decimal Sum);
    record TimeRow(int Hour, int Count);

    class ItemFormModel
    {
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public decimal Price { get; set; }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var token = query["token"] ?? "";
        var code = query["code"] ?? "";
        var venueIdStr = query["venueId"] ?? "";
        if (int.TryParse(venueIdStr, out var vid)) VenueId = vid;

        if (!string.IsNullOrEmpty(code))
        {
            var accessService = ServiceProvider.GetRequiredService<ManagerAccessService>();
            var venueId = accessService.ValidateCode(code);
            if (venueId != null)
            {
                VenueId = venueId.Value;
                authorized = true;
            }
            else
            {
                authorized = false;
                loading = false;
                StateHasChanged();
                return;
            }
        }
        else
        {
            var validToken = Configuration["ManagerToken"];
            if (string.IsNullOrEmpty(token) || token != validToken)
            {
                authorized = false;
                loading = false;
                StateHasChanged();
                return;
            }
            authorized = true;
        }

        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var venue = await db.Venues.FirstOrDefaultAsync(v => v.Id == VenueId);
        venueName = venue?.Name ?? "Заведение";
        await LoadAll();
        loading = false;
        StateHasChanged();
    }

    async Task LoadAll() { await LoadStats(); await LoadItems(); }

    async Task LoadStats()
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var tz = TimeZoneInfo.FindSystemTimeZoneById("Asia/Ashgabat");
        var today = TimeZoneInfo.ConvertTimeFromUtc(DateTime.UtcNow, tz).Date;

        ordersTotal = await db.Orders.CountAsync(o => o.VenueId == VenueId);
        ordersToday = await db.Orders.CountAsync(o => o.VenueId == VenueId && o.CreatedAt >= today);

        var allOrders = await db.Orders
            .Where(o => o.VenueId == VenueId)
            .Include(o => o.OrderItems).ThenInclude(oi => oi.Item)
            .ToListAsync();

        var confirmedOrders = allOrders.Where(o => o.Status == OrderStatus.Confirmed).ToList();

        revenueTotal = confirmedOrders.Sum(o => o.OrderItems.Sum(oi => oi.Item != null ? oi.Item.Price * oi.Quantity : 0));
        revenueToday = confirmedOrders.Where(o => o.CreatedAt >= today)
            .Sum(o => o.OrderItems.Sum(oi => oi.Item != null ? oi.Item.Price * oi.Quantity : 0));
        avgCheck = confirmedOrders.Count > 0 ? revenueTotal / confirmedOrders.Count : 0;

        itemRevenue = confirmedOrders.SelectMany(o => o.OrderItems).Where(oi => oi.Item != null)
            .GroupBy(oi => oi.Item!.Name)
            .Select(g => new ItemRevenueRow(g.Key, g.Sum(x => x.Quantity), g.Sum(x => x.Item!.Price * x.Quantity)))
            .OrderByDescending(x => x.Sum).ToList();

        usersTotal = await db.VenueUsers.CountAsync(vu => vu.VenueId == VenueId && vu.Role == VenueRole.Customer);
        usersToday = await db.VenueUsers.CountAsync(vu => vu.VenueId == VenueId && vu.Role == VenueRole.Customer && vu.JoinedAt >= today);
        itemsCount = await db.Items.CountAsync(i => i.VenueId == VenueId);
        categoriesCount = await db.Categories.CountAsync(c => c.VenueId == VenueId);

        topTimes = allOrders.GroupBy(o => o.CreatedAt.Hour)
            .Select(g => new TimeRow(g.Key, g.Count()))
            .OrderByDescending(x => x.Count).Take(5).ToList();

        categories = await db.Categories.Where(c => c.VenueId == VenueId)
            .OrderBy(c => c.SortOrder).ToListAsync();

        var itemCategoryIds = await db.Items
            .Where(i => i.VenueId == VenueId)
            .Select(i => i.CategoryId)
            .Distinct()
            .ToListAsync();
        categoryHasItems = categories.ToDictionary(c => c.Id, c => itemCategoryIds.Contains(c.Id));

        if (categories.Any() && selectedCategoryId == 0)
            selectedCategoryId = categories.First().Id;
    }

    async Task LoadItems()
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        allItems = await db.Items.Where(i => i.VenueId == VenueId)
            .OrderBy(i => i.CategoryId).ThenBy(i => i.Name).ToListAsync();
    }

    void OpenAddItem()
    {
        editingItem = null; itemForm = new(); addItemError = ""; uploadedImageUrl = "";
        if (categories.Any()) selectedCategoryId = categories.First().Id;
        showAddItem = true;
    }

    void OpenEditItem(Item item)
    {
        editingItem = item;
        itemForm = new ItemFormModel { Name = item.Name, Description = item.Description, Price = item.Price };
        selectedCategoryId = item.CategoryId ?? (categories.Any() ? categories.First().Id : 0);
        uploadedImageUrl = item.ImageUrl ?? "";
        addItemError = "";
        showAddItem = true;
    }

    void CloseAddItem() { showAddItem = false; editingItem = null; }

    async Task PickAndUploadPhoto()
    {
        addItemError = "";
        uploadingPhoto = true;
        StateHasChanged();
        try
        {
            await JS.InvokeVoidAsync("openFilePicker");
            string? url = null;
            for (int i = 0; i < 120; i++)
            {
                await Task.Delay(500);
                url = await JS.InvokeAsync<string?>("getLastUploadedUrl");
                if (url != null) break;
            }
            if (!string.IsNullOrEmpty(url))
                uploadedImageUrl = url;
            else
                addItemError = "Фото не выбрано или ошибка загрузки";
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ {ex.Message}");
            addItemError = "Ошибка загрузки";
        }
        finally
        {
            uploadingPhoto = false;
            StateHasChanged();
        }
    }

    void RemovePhoto() => uploadedImageUrl = "";

    async Task SaveItem()
    {
        addItemError = "";
        if (string.IsNullOrWhiteSpace(itemForm.Name)) { addItemError = "Введите название"; return; }
        if (itemForm.Price <= 0) { addItemError = "Введите цену больше нуля"; return; }

        try
        {
            using var scope = ServiceProvider.CreateScope();
            var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();

            if (editingItem != null)
            {
                var dbItem = await db.Items.FindAsync(editingItem.Id);
                if (dbItem != null)
                {
                    dbItem.Name = itemForm.Name.Trim();
                    dbItem.Description = itemForm.Description?.Trim();
                    dbItem.Price = itemForm.Price;
                    dbItem.CategoryId = selectedCategoryId;
                    if (!string.IsNullOrEmpty(uploadedImageUrl))
                        dbItem.ImageUrl = uploadedImageUrl;
                    else if (string.IsNullOrEmpty(uploadedImageUrl) && !string.IsNullOrEmpty(editingItem.ImageUrl))
                        dbItem.ImageUrl = null;
                }
            }
            else
            {
                db.Items.Add(new Item
                    {
                        VenueId = VenueId,
                        Name = itemForm.Name.Trim(),
                        Description = itemForm.Description?.Trim(),
                        Price = itemForm.Price,
                        CategoryId = selectedCategoryId,
                        ImageUrl = string.IsNullOrEmpty(uploadedImageUrl) ? null : uploadedImageUrl
                    });
            }

            await db.SaveChangesAsync();
            Console.WriteLine($"✅ Товар сохранён: {itemForm.Name}");
            await LoadAll();
            CloseAddItem();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ SaveItem error: {ex.Message}");
            addItemError = $"Ошибка: {ex.Message}";
        }
    }

    void ConfirmDeleteItem(Item item) => itemToDelete = item;
    void CancelDelete() => itemToDelete = null;

    async Task DeleteItem()
    {
        if (itemToDelete == null) return;
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var dbItem = await db.Items.FindAsync(itemToDelete.Id);
        if (dbItem != null) { db.Items.Remove(dbItem); await db.SaveChangesAsync(); }
        itemToDelete = null;
        await LoadAll();
    }

    void OpenCategories() => showCategories = true;
    void CloseCategories() => showCategories = false;

    async Task AddCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategoryName)) return;
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var maxSort = categories.Any() ? categories.Max(c => c.SortOrder) + 1 : 1;
        db.Categories.Add(new Category { VenueId = VenueId, Name = newCategoryName.Trim(), SortOrder = maxSort, IsDefault = false });
        await db.SaveChangesAsync();
        newCategoryName = "";
        await LoadAll();
    }

    async Task AddCategoryInline()
    {
        await AddCategory();
        if (categories.Any()) selectedCategoryId = categories.Last().Id;
    }

    void StartEditCategory(int id, string name) { editingCategoryId = id; editingCategoryName = name; }
    void CancelEditCategory() => editingCategoryId = 0;

    async Task SaveCategory(int id)
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var cat = await db.Categories.FindAsync(id);
        if (cat != null) { cat.Name = editingCategoryName.Trim(); await db.SaveChangesAsync(); }
        editingCategoryId = 0;
        await LoadAll();
    }

    async Task DeleteCategory(int id)
    {
        using var scope = ServiceProvider.CreateScope();
        var db = scope.ServiceProvider.GetRequiredService<AppDbContext>();
        var cat = await db.Categories.FindAsync(id);
        if (cat != null) { db.Categories.Remove(cat); await db.SaveChangesAsync(); }
        await LoadAll();
    }

    async Task SendRevenueReport()
    {
        var msg = $"💰 *Прибыль — {venueName}*\n\n" +
                  $"📅 Сегодня: *{revenueToday:0.00} м* ({ordersToday} заказов)\n" +
                  $"📊 Всего: *{revenueTotal:0.00} м* ({ordersTotal} заказов)\n" +
                  $"🧾 Средний чек: *{avgCheck:0.00} м*";
        await SendTelegramReport(msg);
    }

    async Task SendItemRevenueReport()
    {
        var lines = itemRevenue.Select(i => $"• {i.Name} ×{i.Qty} — {i.Sum:0.00} м");
        var msg = $"📦 *Прибыль по товарам — {venueName}*\n\n" +
                  string.Join("\n", lines) +
                  $"\n\n💰 Итого: *{revenueTotal:0.00} м*";
        await SendTelegramReport(msg);
    }

    async Task SendCatalogReport()
    {
        var msg = $"🗂 *Каталог — {venueName}*\n\n🛍 Товаров: *{itemsCount}*\n📂 Категорий: *{categoriesCount}*";
        await SendTelegramReport(msg);
    }

    async Task SendClientsReport()
    {
        var msg = $"👥 *Клиенты — {venueName}*\n\n🆕 Новых сегодня: *{usersToday}*\n📊 Всего клиентов: *{usersTotal}*";
        await SendTelegramReport(msg);
    }

    async Task SendTelegramReport(string message)
    {
        sendingReport = true; reportStatus = ""; StateHasChanged();
        try
        {
            using var botScope = ServiceProvider.CreateScope();
            var venueHosted = botScope.ServiceProvider.GetRequiredService<VenueHostedService>();
            var botService = venueHosted.GetBotService(VenueId);

            if (botService == null)
            {
                reportStatus = "❌ Бот не найден"; reportSuccess = false; return;
            }

            using var dbScope = ServiceProvider.CreateScope();
            var db = dbScope.ServiceProvider.GetRequiredService<AppDbContext>();

            var managers = await db.VenueUsers
                .Include(vu => vu.AppUser)
                .Where(vu => vu.VenueId == VenueId && vu.Role == VenueRole.Boss)
                .ToListAsync();

            if (!managers.Any())
                managers = await db.VenueUsers
                    .Include(vu => vu.AppUser)
                    .Where(vu => vu.VenueId == VenueId && vu.Role == VenueRole.Operator)
                    .ToListAsync();

            foreach (var m in managers)
                await botService.SendMessageAsync(m.AppUser.TelegramUserId, message);

            reportStatus = $"✅ Отчёт отправлен ({managers.Count} чел.)";
            reportSuccess = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ SendTelegramReport: {ex.Message}");
            reportStatus = "❌ Ошибка отправки";
            reportSuccess = false;
        }
        finally
        {
            sendingReport = false; StateHasChanged();
            await Task.Delay(4000);
            reportStatus = ""; StateHasChanged();
        }
    }
}