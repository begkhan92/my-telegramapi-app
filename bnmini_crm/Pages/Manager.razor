@page "/manager"
@using bnmini_crm.Data
@using bnmini_crm.Models
@using bnmini_crm.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@inject NavigationManager Nav
@inject IConfiguration Configuration
@inject IServiceProvider ServiceProvider
@inject IJSRuntime JS

<div class="mgr-app">

    @if (loading)
    {
        <div class="mgr-loading">
            <div class="mgr-spinner"></div>
            <span>Загрузка...</span>
        </div>
    }
    else if (!authorized)
    {
        <div class="mgr-auth">
            <div class="mgr-auth-icon">🔐</div>
            <div class="mgr-auth-title">Доступ запрещён</div>
            <div class="mgr-auth-sub">Неверный токен</div>
        </div>
    }
    else
    {
        <div class="mgr-header">
            <div>
                <div class="mgr-title">@venueName</div>
                <div class="mgr-subtitle">Панель управления</div>
            </div>
            <div class="mgr-header-badge">MGR</div>
        </div>

        <div class="mgr-stats">
            <div class="stat-card stat-wide">
                <div class="stat-row">
                    <div class="stat-item">
                        <div class="stat-val">@ordersToday</div>
                        <div class="stat-label">Заказов сегодня</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <div class="stat-val">@ordersTotal</div>
                        <div class="stat-label">Всего заказов</div>
                    </div>
                </div>
            </div>
            <div class="stat-card stat-wide">
                <div class="stat-row">
                    <div class="stat-item">
                        <div class="stat-val blue">@revenueToday.ToString("0") м</div>
                        <div class="stat-label">Выручка сегодня</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <div class="stat-val blue">@revenueTotal.ToString("0") м</div>
                        <div class="stat-label">Выручка всего</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-val green">@avgCheck.ToString("0") м</div>
                <div class="stat-label">Средний чек</div>
            </div>
            <div class="stat-card">
                <div class="stat-row">
                    <div class="stat-item">
                        <div class="stat-val">@usersToday</div>
                        <div class="stat-label">Новых</div>
                    </div>
                    <div class="stat-divider"></div>
                    <div class="stat-item">
                        <div class="stat-val">@usersTotal</div>
                        <div class="stat-label">Клиентов</div>
                    </div>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-val">@itemsCount</div>
                <div class="stat-label">Товаров</div>
            </div>
            <div class="stat-card">
                <div class="stat-val">@categoriesCount</div>
                <div class="stat-label">Категорий</div>
            </div>
        </div>

        <div class="mgr-actions">
            <button class="mgr-btn mgr-btn-primary" @onclick="OpenAddItem">
                <span class="btn-icon">➕</span><span>Добавить товар</span>
            </button>
            <button class="mgr-btn mgr-btn-secondary" @onclick="OpenCategories">
                <span class="btn-icon">📂</span><span>Категории</span>
            </button>
        </div>

        <div class="mgr-section-title-outer">📊 Отчёты в Telegram</div>
        <div class="mgr-tg-actions">
            <button class="tg-stat-btn" @onclick="SendRevenueReport" disabled="@sendingReport">
                <span class="tg-btn-icon">💰</span><span>Прибыль</span>
            </button>
            <button class="tg-stat-btn" @onclick="SendItemRevenueReport" disabled="@sendingReport">
                <span class="tg-btn-icon">📦</span><span>По товарам</span>
            </button>
            <button class="tg-stat-btn" @onclick="SendCatalogReport" disabled="@sendingReport">
                <span class="tg-btn-icon">🗂</span><span>Каталог</span>
            </button>
            <button class="tg-stat-btn" @onclick="SendClientsReport" disabled="@sendingReport">
                <span class="tg-btn-icon">👥</span><span>Клиенты</span>
            </button>
        </div>
        @if (!string.IsNullOrEmpty(reportStatus))
        {
            <div class="mgr-report-status @(reportSuccess ? "status-ok" : "status-err")">@reportStatus</div>
        }

        <div class="mgr-section">
            <div class="mgr-section-title">📈 Выручка по товарам</div>
            @if (!itemRevenue.Any())
            {
                <div class="mgr-empty">Заказов пока нет</div>
            }
            else
            {
                @foreach (var ir in itemRevenue)
                {
                    <div class="item-revenue-row">
                        <span class="item-revenue-name">@ir.Name</span>
                        <span class="item-revenue-qty">×@ir.Qty</span>
                        <span class="item-revenue-sum">@ir.Sum.ToString("0.00") м</span>
                    </div>
                }
                <div class="item-revenue-total">
                    <span>Итого</span>
                    <span>@revenueTotal.ToString("0.00") м</span>
                </div>
            }
        </div>

        @if (topTimes.Any())
        {
            <div class="mgr-section">
                <div class="mgr-section-title">⏰ Топ время заказов</div>
                @foreach (var t in topTimes)
                {
                    <div class="item-revenue-row">
                        <span class="item-revenue-name">@t.Hour:00 — @(t.Hour + 1):00</span>
                        <span class="item-revenue-sum">@t.Count зак.</span>
                    </div>
                }
            </div>
        }

        <div class="mgr-section">
            <div class="mgr-section-title">🛍 Товары</div>
            @if (!allItems.Any())
            {
                <div class="mgr-empty">Товаров пока нет</div>
            }
            else
            {
                @foreach (var item in allItems)
                {
                    <div class="item-list-row">
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" class="item-thumb" alt="@item.Name" />
                        }
                        else
                        {
                            <div class="item-thumb-placeholder">📦</div>
                        }
                        <div class="item-list-info">
                            <div class="item-list-name">@item.Name</div>
                            <div class="item-list-meta">
                                @(categories.FirstOrDefault(c => c.Id == item.CategoryId)?.Name ?? "—")
                                · @item.Price.ToString("0.00") м
                            </div>
                        </div>
                        <div class="item-list-actions">
                            <button class="icon-btn edit-btn" @onclick="() => OpenEditItem(item)">✏️</button>
                            <button class="icon-btn del-btn" @onclick="() => ConfirmDeleteItem(item)">🗑</button>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @if (showAddItem)
    {
        <div class="mgr-overlay" @onclick="CloseAddItem"></div>
        <div class="mgr-sheet">
            <div class="sheet-handle"></div>
            <div class="mgr-sheet-header">
                <span>@(editingItem != null ? "✏️ Редактировать" : "➕ Новый товар")</span>
                <button class="mgr-close" @onclick="CloseAddItem">✕</button>
            </div>
            <div class="mgr-sheet-body">
                <label class="mgr-label">Название</label>
                <input class="mgr-input" @bind="itemForm.Name" placeholder="Название товара" />

                <label class="mgr-label">Описание</label>
                <textarea class="mgr-input mgr-textarea" @bind="itemForm.Description" placeholder="Описание (необязательно)"></textarea>

                <label class="mgr-label">Цена (м)</label>
                <input class="mgr-input" type="number" step="0.01" @bind="itemForm.Price" placeholder="0.00" />

                <label class="mgr-label">Категория</label>
                @if (categories.Any())
                {
                    <div class="cat-chips">
                        @foreach (var cat in categories)
                        {
                            <div class="cat-chip @(selectedCategoryId == cat.Id ? "active" : "")"
                                 @onclick="() => selectedCategoryId = cat.Id">
                                @cat.Name
                            </div>
                        }
                    </div>
                }
                <div class="mgr-inline" style="margin-top:8px">
                    <input class="mgr-input" @bind="newCategoryName" placeholder="Новая категория..." />
                    <button class="mgr-btn-sm" @onclick="AddCategoryInline">+</button>
                </div>

                <div class="mgr-inline">
                    <label class="mgr-label" style="margin-top:8px">Фото</label>
                    <button class="mgr-btn-sm" @onclick="PickAndUploadPhoto" disabled="@uploadingPhoto">
                        @(uploadingPhoto ? "⏳ Загрузка..." : "📎 Выбрать и загрузить")
                    </button>
                </div>

                @if (!string.IsNullOrEmpty(uploadedImageUrl))
                {
                    <div class="mgr-preview-wrap">
                        <img src="@uploadedImageUrl" class="mgr-preview" alt="preview" />
                        <button class="mgr-remove-photo" @onclick="RemovePhoto">✕ Убрать фото</button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(addItemError))
                {
                    <div class="mgr-error">@addItemError</div>
                }

                <button class="mgr-btn-primary-full" @onclick="SaveItem">
                    💾 @(editingItem != null ? "Сохранить изменения" : "Добавить товар")
                </button>
            </div>
        </div>
    }

    @if (showCategories)
    {
        <div class="mgr-overlay" @onclick="CloseCategories"></div>
        <div class="mgr-sheet">
            <div class="sheet-handle"></div>
            <div class="mgr-sheet-header">
                <span>📂 Категории</span>
                <button class="mgr-close" @onclick="CloseCategories">✕</button>
            </div>
            <div class="mgr-sheet-body">
                <div class="mgr-inline" style="margin-bottom:12px">
                    <input class="mgr-input" @bind="newCategoryName" placeholder="Название новой категории" />
                    <button class="mgr-btn-sm" @onclick="AddCategory">+</button>
                </div>
                @foreach (var cat in categories)
                {
                    <div class="cat-edit-row">
                        @if (editingCategoryId == cat.Id)
                        {
                            <input class="mgr-input" @bind="editingCategoryName" style="flex:1" />
                            <button class="mgr-btn-sm" @onclick="() => SaveCategory(cat.Id)">✓</button>
                            <button class="mgr-btn-sm-cancel" @onclick="CancelEditCategory">✕</button>
                        }
                        else
                        {
                            <span class="cat-edit-name">@cat.Name</span>
                            <span class="cat-item-count">@(categoryHasItems.GetValueOrDefault(cat.Id, false) ? "есть товары" : "пусто")</span>
                            <button class="icon-btn edit-btn" @onclick="() => StartEditCategory(cat.Id, cat.Name)">✏️</button>
                            @if (!categoryHasItems.GetValueOrDefault(cat.Id, false))
                            {
                                <button class="icon-btn del-btn" @onclick="() => DeleteCategory(cat.Id)">🗑</button>
                            }
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (itemToDelete != null)
    {
        <div class="mgr-overlay" @onclick="CancelDelete"></div>
        <div class="mgr-confirm-modal">
            <div class="confirm-title">Удалить товар?</div>
            <div class="confirm-sub">«@itemToDelete.Name» будет удалён без возможности восстановления</div>
            <div class="confirm-actions">
                <button class="mgr-btn-sm-cancel" @onclick="CancelDelete">Отмена</button>
                <button class="mgr-btn-sm-danger" @onclick="DeleteItem">Удалить</button>
            </div>
        </div>
    }

</div>

<style>
    *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: #f0f0f5;
        font-family: -apple-system, 'SF Pro Text', 'Segoe UI', sans-serif;
    }

    .mgr-app {
        max-width: 480px;
        margin: 0 auto;
        min-height: 100vh;
        background: #f0f0f5;
        padding-bottom: 48px;
    }

    .mgr-auth {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        gap: 8px;
    }

    .mgr-auth-icon {
        font-size: 48px;
    }

    .mgr-auth-title {
        font-size: 22px;
        font-weight: 700;
    }

    .mgr-auth-sub {
        font-size: 14px;
        color: #8e8e93;
    }

    .mgr-loading {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        padding: 80px 0;
        font-size: 15px;
        color: #8e8e93;
    }

    .mgr-spinner {
        width: 24px;
        height: 24px;
        border: 3px solid #e0e0e5;
        border-top-color: #007aff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    .mgr-header {
        background: #fff;
        padding: 20px 16px 16px;
        border-bottom: 1px solid #e5e5ea;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .mgr-title {
        font-size: 20px;
        font-weight: 700;
        color: #000;
    }

    .mgr-subtitle {
        font-size: 13px;
        color: #8e8e93;
        margin-top: 2px;
    }

    .mgr-header-badge {
        background: #007aff;
        color: #fff;
        font-size: 11px;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 8px;
        letter-spacing: 0.5px;
    }

    .mgr-stats {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        padding: 14px 16px 0;
    }

    .stat-card {
        background: #fff;
        border-radius: 16px;
        padding: 14px 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }

    .stat-wide {
        grid-column: span 2;
    }

    .stat-row {
        display: flex;
        align-items: center;
    }

    .stat-item {
        flex: 1;
    }

    .stat-divider {
        width: 1px;
        height: 36px;
        background: #e5e5ea;
        margin: 0 16px;
        flex-shrink: 0;
    }

    .stat-val {
        font-size: 22px;
        font-weight: 700;
        color: #000;
        line-height: 1.1;
    }

        .stat-val.blue {
            color: #007aff;
        }

        .stat-val.green {
            color: #34c759;
        }

    .stat-label {
        font-size: 11px;
        color: #8e8e93;
        margin-top: 3px;
    }

    .mgr-actions {
        display: flex;
        gap: 10px;
        padding: 14px 16px 0;
    }

    .mgr-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 14px 10px;
        border: none;
        border-radius: 14px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        -webkit-tap-highlight-color: transparent;
        transition: opacity 0.15s;
    }

        .mgr-btn:active {
            opacity: 0.75;
        }

    .mgr-btn-primary {
        background: #007aff;
        color: #fff;
    }

    .mgr-btn-secondary {
        background: #fff;
        color: #007aff;
        box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }

    .btn-icon {
        font-size: 16px;
    }

    .mgr-section-title-outer {
        font-size: 13px;
        font-weight: 600;
        color: #8e8e93;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 16px 16px 8px;
    }

    .mgr-tg-actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        padding: 0 16px;
    }

    .tg-stat-btn {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 13px 14px;
        background: #fff;
        border: none;
        border-radius: 14px;
        font-size: 14px;
        font-weight: 500;
        color: #000;
        cursor: pointer;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
        -webkit-tap-highlight-color: transparent;
        transition: opacity 0.15s;
    }

        .tg-stat-btn:active {
            opacity: 0.65;
        }

        .tg-stat-btn:disabled {
            opacity: 0.45;
            cursor: not-allowed;
        }

    .tg-btn-icon {
        font-size: 18px;
    }

    .mgr-report-status {
        margin: 10px 16px 0;
        padding: 10px 14px;
        border-radius: 12px;
        font-size: 13px;
        font-weight: 500;
    }

    .status-ok {
        background: #d4f5e0;
        color: #1a7f3c;
    }

    .status-err {
        background: #ffe4e4;
        color: #c0392b;
    }

    .mgr-section {
        margin: 14px 16px 0;
        background: #fff;
        border-radius: 16px;
        padding: 16px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.07);
    }

    .mgr-section-title {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #000;
    }

    .mgr-empty {
        font-size: 14px;
        color: #8e8e93;
        padding: 8px 0;
    }

    .item-revenue-row {
        display: flex;
        align-items: center;
        padding: 9px 0;
        border-bottom: 1px solid #f2f2f7;
        gap: 8px;
    }

    .item-revenue-name {
        flex: 1;
        font-size: 14px;
        color: #000;
    }

    .item-revenue-qty {
        font-size: 13px;
        color: #8e8e93;
    }

    .item-revenue-sum {
        font-size: 14px;
        font-weight: 600;
        color: #007aff;
    }

    .item-revenue-total {
        display: flex;
        justify-content: space-between;
        padding-top: 10px;
        font-weight: 700;
        font-size: 15px;
    }

    .item-list-row {
        display: flex;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f2f2f7;
        gap: 12px;
    }

    .item-thumb {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        object-fit: cover;
        flex-shrink: 0;
    }

    .item-thumb-placeholder {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        background: #f2f2f7;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        flex-shrink: 0;
    }

    .item-list-info {
        flex: 1;
        min-width: 0;
    }

    .item-list-name {
        font-size: 15px;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .item-list-meta {
        font-size: 12px;
        color: #8e8e93;
        margin-top: 2px;
    }

    .item-list-actions {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .icon-btn {
        width: 34px;
        height: 34px;
        background: #f2f2f7;
        border: none;
        border-radius: 50%;
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        -webkit-tap-highlight-color: transparent;
    }

    .edit-btn:active {
        background: #e0e8ff;
    }

    .del-btn:active {
        background: #ffe4e4;
    }

    .mgr-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.42);
        z-index: 300;
    }

    .mgr-sheet {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: #fff;
        border-radius: 20px 20px 0 0;
        z-index: 400;
        max-height: 92vh;
        display: flex;
        flex-direction: column;
        max-width: 480px;
        margin: 0 auto;
    }

    .sheet-handle {
        width: 36px;
        height: 4px;
        background: #e0e0e5;
        border-radius: 2px;
        margin: 10px auto 0;
        flex-shrink: 0;
    }

    .mgr-sheet-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 20px 12px;
        border-bottom: 1px solid #f2f2f7;
        font-size: 17px;
        font-weight: 700;
        flex-shrink: 0;
    }

    .mgr-close {
        width: 28px;
        height: 28px;
        background: #f2f2f7;
        border: none;
        border-radius: 50%;
        font-size: 13px;
        color: #8e8e93;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mgr-sheet-body {
        padding: 16px 20px 32px;
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .mgr-label {
        font-size: 11px;
        font-weight: 600;
        color: #8e8e93;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
        margin-bottom: 4px;
    }

    .mgr-input {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid #e0e0e5;
        border-radius: 12px;
        font-size: 15px;
        color: #000;
        outline: none;
        background: #fafafa;
        font-family: inherit;
    }

        .mgr-input:focus {
            border-color: #007aff;
            background: #fff;
        }

    .mgr-textarea {
        resize: vertical;
        min-height: 72px;
    }

    .mgr-inline {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .cat-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 6px;
    }

    .cat-chip {
        padding: 6px 12px;
        background: #f2f2f7;
        border-radius: 50px;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.12s;
        border: 1.5px solid transparent;
    }

        .cat-chip.active {
            background: #e8f0ff;
            border-color: #007aff;
            color: #007aff;
        }

    .mgr-preview-wrap {
        position: relative;
    }

    .mgr-preview {
        width: 100%;
        border-radius: 12px;
        max-height: 200px;
        object-fit: cover;
    }

    .mgr-remove-photo {
        position: absolute;
        top: 8px;
        right: 8px;
        background: rgba(0,0,0,0.6);
